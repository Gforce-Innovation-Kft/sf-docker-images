# Copy to .env next to docker-compose.yml — and GIT-IGNORE .env.
# Never bake credentials into images or commit them.
#
# Get the auth URL for an org you are already logged into on your host:
#   sf org display --target-org <alias> --verbose --json | jq -r '.result.sfdxAuthUrl'
# In CI, store this value as a secret (e.g. GitHub Actions secret) instead.
SF_AUTH_URL=force://PlatformCLI::REPLACE_ME@yourcompany.my.salesforce.com
